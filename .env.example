# DDNS Server Configuration Template
# Copy this file to .env and fill in your values.
# The setup.sh script generates .env automatically — prefer running that.

# DNS provider: "duckdns" (default), "cloudflare", or "digitalocean"
PROVIDER=duckdns

# ── DuckDNS (when PROVIDER=duckdns) ────────────────────────────────────────
# Free account at duckdns.org — no domain needed.
# Token: shown at the top of the page after login.
# Domain: subdomain only (e.g. "myhome" → myhome.duckdns.org).
DUCK_TOKEN=your_duckdns_token_here
DUCK_DOMAIN=myhome

# ── Cloudflare (when PROVIDER=cloudflare) ──────────────────────────────────
# Free account + your own domain on Cloudflare.
# Token: dash.cloudflare.com → My Profile → API Tokens → "Edit zone DNS" template.
# CF_TOKEN=your_cloudflare_token_here
# CF_ZONE_ID=32char_hex_zone_id
# CF_RECORD_ID=32char_hex_record_id

# ── DigitalOcean (when PROVIDER=digitalocean) ──────────────────────────────
# Token: cloud.digitalocean.com → API → Tokens (Read + Write).
# TOKEN=your_digitalocean_token_here
# DOMAIN=example.com
# RECORD_ID=123456789

# ── DDNS Authentication (router credentials) ───────────────────────────────
DDNS_USERNAME=your_ddns_username
DDNS_PASSWORD=your_ddns_password

# ── Server ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1   # bind to loopback; nginx proxies in front
PORT=9876
DEBUG=false
TRUST_PROXY=true  # honor X-Forwarded-For from nginx
